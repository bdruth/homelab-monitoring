INDEXER_APP_URL=http://example.indexer-app.local
INDEXER_APP_NAME=ExampleIndexerApp
INDEXER_NAME=ExampleIndexer

# Dashboard app settings
DASHBOARD_APP_URL=http://example.dashboard-app.local
DASHBOARD_APP_NAME=ExampleDashboardApp
DASHBOARD_URL_WILDCARD=**/example.dashboard-app.local/**
AUTH_URL_WILDCARD=**/example.auth.local/**

# Auth settings for 1Password
SERVICE_ACCOUNT_VAULT=your-1password-vault
SERVICE_ACCOUNT_ITEM=your-1password-item-name
# TOTP seed, NOT a 6-digit code. Accepts either a raw base32 seed or the full
# otpauth://...?secret=...&... URI (what a 1Password OTP field returns when
# referenced without ?attribute=otp). The dashboard test generates a fresh code
# from it at runtime via otplib. In CI this is injected from 1Password.
AUTH_TOTP_SECRET=otpauth://totp/Example:user?secret=YOURBASE32SEED&issuer=Example

# Workflow app settings
WORKFLOW_APP_URL=http://example.workflow-app.local
WORKFLOW_APP_NAME=ExampleWorkflowApp
WORKFLOW_URL_WILDCARD=**/example.workflow-app.local/**

# Workflow Auth settings for 1Password
WORKFLOW_SERVICE_ACCOUNT_VAULT=your-1password-vault
WORKFLOW_SERVICE_ACCOUNT_ITEM=your-1password-item-name

GITEA_HOST=http://example.gitea.local
